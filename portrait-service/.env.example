PORTRAIT_BASE_URL=http://localhost:8000
PORTRAIT_GENERATOR=fake          # fake | openai
PORTRAIT_STORAGE=local
PORTRAIT_STORAGE_DIR=./_data/images
PORTRAIT_MAX_MOTIFS=4
PORTRAIT_GENERATION_TIMEOUT_S=120

# only used when PORTRAIT_GENERATOR=openai
PORTRAIT_OPENAI_API_KEY=
PORTRAIT_OPENAI_MODEL=gpt-image-1-mini   # gpt-image-1-mini | gpt-image-1 | gpt-image-1.5
PORTRAIT_OPENAI_SIZE=1024x1536           # portrait orientation
PORTRAIT_OPENAI_QUALITY=medium           # low | medium | high
PORTRAIT_OPENAI_MODERATION=auto          # auto | low
